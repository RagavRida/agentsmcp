{
  "name": "agentsmcp-adapter",
  "version": "0.1.0",
  "description": "MCP server adapter for agentsmcp (AgentMailbox)",
  "bin": {
    "agentsmcp-adapter": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/finalize.js",
    "start": "ts-node src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentsmcp",
    "agentmailbox",
    "mcp",
    "model-context-protocol",
    "agents",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RagavRida/agentmailbox.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/RagavRida/agentmailbox/tree/main/mcp",
  "bugs": {
    "url": "https://github.com/RagavRida/agentmailbox/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "agentsmcp": "^0.2.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
